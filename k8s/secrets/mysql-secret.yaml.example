# Example MySQL secret file - Copy this to mysql-secret.yaml and fill in real values
# This file is safe to commit since it contains no real secrets

apiVersion: v1
kind: Secret
metadata:
  name: mysql-secret
  namespace: agentlog
  labels:
    app: mysql
    component: database
type: Opaque
stringData:
  # Replace with your actual database credentials
  mysql-database: "agentlog"
  mysql-host: "your-mysql-host.com"  
  mysql-password: "your-mysql-password-here"
  mysql-port: "25060"
  mysql-user: "your-mysql-username" 