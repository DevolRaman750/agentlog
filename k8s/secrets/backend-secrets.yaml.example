# Example backend secrets file - Copy this to backend-secrets.yaml and fill in real values
# This file is safe to commit since it contains no real secrets

apiVersion: v1
kind: Secret
metadata:
  name: agentlog-backend-secrets
  namespace: agentlog
type: Opaque
stringData:
  # Database connection string
  DB_URL: "mysql://user:password@tcp(mysql-host:3306)/agentlog"
  
  # Gemini API key (get from https://aistudio.google.com/app/apikey)
  GEMINI_API_KEY: "your-gemini-api-key-here"
  
  # JWT secret for authentication (generate a random string)
  JWT_SECRET: "your-jwt-secret-change-me"
  
  # API encryption key (minimum 32 characters)
  API_ENCRYPTION_KEY: "your-api-encryption-key-minimum-32-chars"
  
  # Optional: Email configuration if using email features
  # SMTP_HOST: "smtp.gmail.com"
  # SMTP_PORT: "587"
  # SMTP_USER: "your-email@gmail.com"
  # SMTP_PASS: "your-app-password" 