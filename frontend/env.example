# AgentLog Environment Configuration
# Copy this file to .env.local and fill in your actual values

# App Configuration
APP_ENV=production
APP_VERSION=1.0.0

# Backend API Configuration
API_BASE_URL=https://your-api-domain.com
API_TIMEOUT=30000
GRPC_ENDPOINT=https://your-grpc-endpoint.com

# Third-Party Service Configuration
# These are managed through the app's API key management
# Listed here for reference only

# Google Gemini (configured in app)
# GEMINI_API_KEY=your_gemini_api_key

# OpenAI (configured in app)  
# OPENAI_API_KEY=your_openai_api_key

# Anthropic Claude (configured in app)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# Analytics and Monitoring (optional)
ANALYTICS_ENABLED=false
# ANALYTICS_API_KEY=your_analytics_key
# SENTRY_DSN=your_sentry_dsn

# Feature Flags
ENABLE_DEBUG_LOGS=false
ENABLE_CRASH_REPORTING=true
ENABLE_ANALYTICS=false
ENABLE_EXPERIMENTAL_FEATURES=false

# App Store and Distribution
EAS_PROJECT_ID=your-eas-project-id-here
APP_STORE_ID=your-app-store-id
GOOGLE_PLAY_APP_ID=com.agentlog.app

# Security Configuration
ENCRYPTION_KEY_VERSION=v1
API_KEY_STORAGE_VERSION=v1

# Support and Legal
SUPPORT_EMAIL=support@agentlog.com
PRIVACY_POLICY_URL=https://agentlog.com/privacy
TERMS_OF_SERVICE_URL=https://agentlog.com/terms
SUPPORT_URL=https://agentlog.com/support

# Development/Testing (not used in production)
MOCK_API_RESPONSES=false
BYPASS_AUTH=false
USE_LOCAL_STORAGE=false