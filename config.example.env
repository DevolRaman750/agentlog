# Database configuration
DATABASE_URL=mysql://username:password@localhost:3306/gogent_db

# Gemini API configuration (server-side fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT configuration
JWT_SECRET=your_jwt_secret_here

# Server configuration
PORT=8080
HOST=localhost

# API Key Encryption (unified for both frontend and backend)
# Backend uses: API_ENCRYPTION_KEY
# Frontend uses: EXPO_PUBLIC_API_ENCRYPTION_KEY (React Native requirement)
# Set both to the same value for consistency
API_ENCRYPTION_KEY=gogent_secure_encryption_key_2025_development_minimum_32_characters
EXPO_PUBLIC_API_ENCRYPTION_KEY=gogent_secure_encryption_key_2025_development_minimum_32_characters

# Email configuration (optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# FROM_EMAIL=your_email@gmail.com

# HeartbeatExecutor configuration
# Enable/disable the heartbeat executor for autonomous agents
HEARTBEAT_ENABLED=true

# How often to check for overdue agents (in minutes, minimum 1)
HEARTBEAT_CHECK_INTERVAL=5

# Maximum number of agents that can execute simultaneously
HEARTBEAT_MAX_CONCURRENT=10

# Maximum execution timeout per agent (in minutes)
HEARTBEAT_EXECUTION_TIMEOUT=10

# Number of retry attempts for failed executions
HEARTBEAT_RETRY_ATTEMPTS=3

# Enable/disable token limit checking for agents
HEARTBEAT_TOKEN_CHECK=true 