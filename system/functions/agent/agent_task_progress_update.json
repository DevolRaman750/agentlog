{
  "id": "func-agent-task-progress-update",
  "name": "agent_task_progress_update",
  "provider": "internal",
  "function_group": "internal",
  "display_name": "Agent Task Progress: Update",
  "description": "Update progress tracking for a task the agent is working on. Use this to save work-in-progress data, execution state, gathered artifacts, and next steps. This ensures work survives execution interruptions and enables seamless recovery.",
  "endpoint": {
    "path": "/internal/agent/task/progress/update",
    "method": "POST"
  },
  "parameters": {
    "type": "object",
    "required": [
      "task_id",
      "progress_data"
    ],
    "properties": {
      "task_id": {
        "type": "string",
        "description": "The team task ID this progress relates to"
      },
      "progress_data": {
        "type": "object",
        "description": "Progress tracking data structure",
        "required": ["status", "last_updated"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["claimed", "in_progress", "checkpoint", "completed", "error"],
            "description": "Current execution status"
          },
          "last_updated": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp of last progress update (ISO 8601)"
          },
          "current_step": {
            "type": "string",
            "description": "Current step or phase being executed"
          },
          "completed_steps": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "step_name": {"type": "string"},
                "completed_at": {"type": "string", "format": "date-time"},
                "result": {"type": "string"},
                "artifacts": {"type": "object"}
              }
            },
            "description": "List of completed steps with timestamps and results"
          },
          "gathered_data": {
            "type": "object",
            "description": "Data collected during task execution (API responses, file contents, etc.)"
          },
          "artifacts_created": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {"type": "string"},
                "identifier": {"type": "string"},
                "url": {"type": "string"},
                "description": {"type": "string"}
              }
            },
            "description": "Artifacts created during task execution (PRs, issues, messages, etc.)"
          },
          "next_actions": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Planned next steps or actions to take"
          },
          "error_context": {
            "type": "object",
            "properties": {
              "error_type": {"type": "string"},
              "error_message": {"type": "string"},
              "error_step": {"type": "string"},
              "retry_attempts": {"type": "integer"},
              "can_retry": {"type": "boolean"},
              "suggested_fix": {"type": "string"}
            },
            "description": "Error context if task encountered issues"
          },
          "execution_context": {
            "type": "object",
            "description": "Additional execution context (environment, dependencies, etc.)"
          }
        }
      },
      "checkpoint_reason": {
        "type": "string",
        "description": "Reason for creating this checkpoint (milestone, error recovery, etc.)"
      }
    }
  },
  "examples": [
    {
      "name": "Update task progress after claiming",
      "parameters": {
        "task_id": "task_abc123",
        "progress_data": {
          "status": "claimed",
          "last_updated": "2024-01-15T10:30:00Z",
          "current_step": "analyzing_requirements",
          "completed_steps": [],
          "next_actions": ["Read task requirements", "Check team memory for similar tasks", "Plan execution approach"]
        },
        "checkpoint_reason": "Task claimed, starting execution"
      }
    },
    {
      "name": "Update progress after gathering data",
      "parameters": {
        "task_id": "task_abc123",
        "progress_data": {
          "status": "in_progress",
          "last_updated": "2024-01-15T10:45:00Z",
          "current_step": "creating_pull_request",
          "completed_steps": [
            {
              "step_name": "analyzed_requirements",
              "completed_at": "2024-01-15T10:35:00Z",
              "result": "Requirements understood, need to create PR for feature X"
            },
            {
              "step_name": "gathered_context",
              "completed_at": "2024-01-15T10:40:00Z",
              "result": "Found similar PR #42, will use as reference"
            }
          ],
          "gathered_data": {
            "similar_pr": "#42",
            "repository": "owner/repo",
            "branch_name": "feature/xyz"
          },
          "next_actions": ["Create branch", "Make changes", "Create pull request"]
        },
        "checkpoint_reason": "Data gathering complete, proceeding with implementation"
      }
    },
    {
      "name": "Update progress with error context",
      "parameters": {
        "task_id": "task_abc123",
        "progress_data": {
          "status": "error",
          "last_updated": "2024-01-15T11:00:00Z",
          "current_step": "creating_pull_request",
          "completed_steps": [
            {
              "step_name": "created_branch",
              "completed_at": "2024-01-15T10:50:00Z",
              "result": "Branch 'feature/xyz' created successfully"
            }
          ],
          "error_context": {
            "error_type": "api_error",
            "error_message": "GitHub API rate limit exceeded",
            "error_step": "creating_pull_request",
            "retry_attempts": 1,
            "can_retry": true,
            "suggested_fix": "Wait 1 hour for rate limit reset, then retry"
          },
          "next_actions": ["Wait for rate limit reset", "Retry PR creation"]
        },
        "checkpoint_reason": "API error encountered, saving state for retry"
      }
    }
  ]
}
