{
  "id": "func-agent-task-list",
  "name": "agent_task_list",
  "provider": "internal",
  "function_group": "internal",
  "display_name": "Agent Task List",
  "description": "Retrieve a list of tasks from the agent's personal task tracking system. Used by agents to query their own stored tasks, reporting history, or personal task queue with flexible filtering options.",
  "endpoint": {
    "path": "/internal/agent/task/list",
    "method": "GET"
  },
  "parameters": {
    "type": "object",
    "properties": {
      "context": {
        "type": "string",
        "default": "agent_tasks",
        "description": "Storage context/category to query (e.g., 'reported_tasks', 'personal_queue')"
      },
      "status": {
        "type": "string",
        "description": "Filter tasks by status (e.g., 'pending', 'completed', 'reported')"
      },
      "limit": {
        "type": "integer",
        "default": 50,
        "minimum": 1,
        "maximum": 500,
        "description": "Maximum number of tasks to return"
      },
      "since": {
        "type": "string",
        "description": "ISO timestamp - only return tasks created/updated after this time"
      },
      "include_metadata": {
        "type": "boolean",
        "default": true,
        "description": "Whether to include full metadata in results"
      }
    }
  },
  "examples": [
    {
      "name": "Get all reported tasks",
      "parameters": {
        "context": "reported_tasks",
        "limit": 100
      }
    },
    {
      "name": "Get recent pending tasks",
      "parameters": {
        "status": "pending",
        "since": "2024-01-15T00:00:00Z",
        "limit": 20
      }
    },
    {
      "name": "Get completed tasks with metadata",
      "parameters": {
        "status": "completed",
        "include_metadata": true,
        "limit": 30
      }
    }
  ]
}