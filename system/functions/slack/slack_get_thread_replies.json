{
  "id": "00000000-0000-0000-0000-000000000088",
  "name": "slack_get_thread_replies",
  "provider": "slack",
  "display_name": "Slack Get Thread Replies",
  "description": "Retrieve thread replies for a message",
  "endpoint": {
    "path": "/conversations.replies",
    "method": "GET"
  },
  "parameters": {
    "type": "object",
    "properties": {
      "channel": {
        "type": "string",
        "description": "Channel containing the message"
      },
      "ts": {
        "type": "string",
        "description": "Timestamp of the parent message"
      },
      "limit": {
        "type": "integer",
        "default": 1000,
        "maximum": 1000,
        "minimum": 1,
        "description": "Maximum number of replies to return (1-1000, default 1000)"
      },
      "inclusive": {
        "type": "boolean",
        "default": false,
        "description": "Include the parent message in results"
      }
    },
    "required": [
      "channel",
      "ts"
    ]
  },
  "examples": [
    {
      "name": "Basic usage",
      "parameters": {}
    }
  ]
}