{
  "id": "00000000-0000-0000-0000-000000000089",
  "name": "slack_update_message",
  "provider": "slack",
  "display_name": "Slack Update Message",
  "description": "Update/edit a message that was previously sent",
  "endpoint": {
    "path": "/chat.update",
    "method": "POST"
  },
  "parameters": {
    "required": ["channel", "ts"],
    "optional": ["text", "blocks", "attachments"],
    "schema": {
      "type": "object",
      "properties": {
        "channel": {
          "type": "string",
          "description": "Channel containing the message"
        },
        "ts": {
          "type": "string",
          "description": "Timestamp of the message to update"
        },
        "text": {
          "type": "string",
          "description": "New text for the message"
        },
        "blocks": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "Structured blocks to replace the message content"
        },
        "attachments": {
          "type": "array",
          "items": {
            "type": "object"
          },
          "description": "Secondary attachments for the message"
        }
      },
      "required": ["channel", "ts"]
    }
  },
  "examples": [
    {
      "name": "Basic usage",
      "parameters": {}
    }
  ]
}
