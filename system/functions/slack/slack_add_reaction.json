{
  "id": "00000000-0000-0000-0000-000000000087",
  "name": "slack_add_reaction",
  "provider": "slack",
  "display_name": "Slack Add Reaction",
  "description": "Add an emoji reaction to a message",
  "endpoint": {
    "path": "/reactions.add",
    "method": "POST"
  },
  "parameters": {
    "required": ["channel", "timestamp", "name"],
    "optional": [],
    "schema": {
      "type": "object",
      "required": ["channel", "timestamp", "name"],
      "properties": {
        "channel": {
          "type": "string",
          "description": "Channel ID containing the message (e.g., C1234567890)"
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp of the message to react to (e.g., 1234567890.123456)"
        },
        "name": {
          "type": "string",
          "description": "Emoji name (without colons, e.g., \"thumbsup\", \"white_check_mark\")"
        }
      }
    }
  },
  "examples": [
    {
      "name": "Add thumbs up reaction",
      "parameters": {
        "channel": "C1234567890",
        "timestamp": "1234567890.123456",
        "name": "thumbsup"
      }
    },
    {
      "name": "Add check mark reaction",
      "parameters": {
        "channel": "C1234567890",
        "timestamp": "1234567890.123456",
        "name": "white_check_mark"
      }
    }
  ]
}