{
  "id": "00000000-0000-0000-0000-000000000084",
  "name": "slack_send_message",
  "provider": "slack",
  "display_name": "Send Slack Message",
  "description": "Send messages to Slack channels or users with rich formatting and attachments. IMPORTANT: Use channel IDs (e.g., 'C099KTQE1L5') from slack_find_channel for reliable delivery. Channel names may work but channel IDs are preferred to avoid 'channel_not_found' errors.",
  "endpoint": {
    "path": "/chat.postMessage",
    "method": "POST"
  },
  "parameters": {
    "type": "object",
    "properties": {
      "channel": {
        "type": "string",
        "description": "Channel ID (e.g., C1234567890) from slack_find_channel, or channel name (e.g., general), or user ID (@username). Channel IDs are most reliable."
      },
      "text": {
        "type": "string",
        "description": "Message text content. Supports Slack markdown formatting"
      },
      "username": {
        "type": "string",
        "description": "Bot username to display (optional)"
      },
      "thread_ts": {
        "type": "string",
        "description": "Timestamp of parent message to reply in thread"
      },
      "icon_emoji": {
        "type": "string",
        "description": "Emoji to use as bot icon (e.g. :robot_face:)"
      },
      "attachments": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "description": "Attachment text"
            },
            "color": {
              "type": "string",
              "description": "Attachment color bar"
            },
            "title": {
              "type": "string",
              "description": "Attachment title"
            },
            "footer": {
              "type": "string",
              "description": "Footer text"
            },
            "image_url": {
              "type": "string",
              "description": "Image URL to display"
            }
          }
        },
        "description": "Rich message attachments (optional)"
      }
    },
    "required": [
      "channel",
      "text"
    ]
  },
  "parameter_dependencies": {
    "channel": {
      "source_function": "slack_find_channel",
      "extraction_path": "channels[0].id",
      "description": "Auto-extract channel ID from slack_find_channel results. Use this to avoid 'channel_not_found' errors."
    }
  },
  "examples": [
    {
      "name": "Simple message to channel",
      "parameters": {
        "channel": "#general",
        "text": "Hello from the AI assistant!"
      }
    },
    {
      "name": "Message to specific channel",
      "parameters": {
        "channel": "#ai-code-updates",
        "text": "Code updates have been deployed successfully!"
      }
    },
    {
      "name": "Threaded reply",
      "parameters": {
        "channel": "#ai-intern",
        "text": "This is a reply to a thread",
        "thread_ts": "1234567890.123456"
      }
    },
    {
      "name": "Message using channel ID",
      "parameters": {
        "channel": "C1234567890",
        "text": "Message using channel ID"
      }
    }
  ]
}