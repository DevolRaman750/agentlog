{
  "id": "func-team_task_clear-1756163000",
  "name": "team_task_clear",
  "provider": "internal",
  "display_name": "Team Task: Clear",
  "description": "Clear, delete, or manage team tasks for consolidation and cleanup. Use this to remove completed tasks, delete duplicates, clear all tasks, or selectively remove tasks by criteria. Helps maintain a clean and organized team task list.",
  "endpoint": {
    "path": "/internal/team/task/clear",
    "method": "POST"
  },
  "parameters": {
    "type": "object",
    "properties": {
      "action": {
        "type": "string",
        "enum": [
          "clear_all",
          "clear_completed",
          "clear_failed",
          "clear_cancelled",
          "delete_task",
          "delete_duplicates",
          "clear_by_status",
          "clear_by_priority",
          "clear_old_tasks"
        ],
        "description": "The clearing action to perform"
      },
      "task_id": {
        "type": "string",
        "description": "Specific task ID to delete (required for delete_task action)"
      },
      "status_filter": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["pending", "claimed", "in_progress", "completed", "failed", "blocked", "cancelled"]
        },
        "description": "Clear tasks with these statuses (required for clear_by_status)"
      },
      "priority_filter": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": ["low", "medium", "high", "urgent"]
        },
        "description": "Clear tasks with these priority levels (required for clear_by_priority)"
      },
      "older_than_days": {
        "type": "integer",
        "minimum": 1,
        "description": "Clear tasks older than this many days (required for clear_old_tasks)"
      },
      "duplicate_criteria": {
        "type": "string",
        "enum": ["title", "title_and_description", "exact_match"],
        "default": "title",
        "description": "How to identify duplicate tasks (for delete_duplicates action)"
      },
      "keep_newest": {
        "type": "boolean",
        "default": true,
        "description": "When removing duplicates, keep the newest task (false = keep oldest)"
      },
      "confirmation": {
        "type": "boolean",
        "default": false,
        "description": "Set to true to confirm destructive operations like clear_all"
      },
      "reason": {
        "type": "string",
        "description": "Optional reason for the clearing action (logged for audit purposes)"
      }
    },
    "required": [
      "action"
    ]
  },
  "examples": [
    {
      "name": "Clear all completed tasks",
      "parameters": {
        "action": "clear_completed",
        "reason": "Weekly cleanup of completed tasks"
      }
    },
    {
      "name": "Delete a specific duplicate task",
      "parameters": {
        "action": "delete_task",
        "task_id": "task_12345",
        "reason": "Removing duplicate task"
      }
    },
    {
      "name": "Remove duplicate tasks by title",
      "parameters": {
        "action": "delete_duplicates",
        "duplicate_criteria": "title",
        "keep_newest": true,
        "reason": "Consolidating duplicate GitHub summary tasks"
      }
    },
    {
      "name": "Clear failed and cancelled tasks",
      "parameters": {
        "action": "clear_by_status",
        "status_filter": ["failed", "cancelled"],
        "reason": "Cleaning up failed task attempts"
      }
    },
    {
      "name": "Clear low priority tasks older than 7 days",
      "parameters": {
        "action": "clear_by_priority",
        "priority_filter": ["low"],
        "older_than_days": 7,
        "reason": "Removing old low priority tasks"
      }
    },
    {
      "name": "Clear all tasks (with confirmation)",
      "parameters": {
        "action": "clear_all",
        "confirmation": true,
        "reason": "Resetting team task list for new project phase"
      }
    },
    {
      "name": "Clear tasks older than 30 days",
      "parameters": {
        "action": "clear_old_tasks",
        "older_than_days": 30,
        "reason": "Monthly cleanup of old tasks"
      }
    }
  ]
}