{
  "id": "func-team_memory_search-1754848206",
  "name": "team_memory_search",
  "provider": "internal",
  "display_name": "Team Memory: Search",
  "description": "Search through the team's shared memory using semantic queries, patterns, or filters. This helps find relevant information when you don't know the exact location, or need to discover patterns across different team memory contexts. Team context is automatically inferred from the agent's team membership.",
  "endpoint": {
    "path": "/internal/team/memory/search",
    "method": "POST"
  },
  "parameters": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Search query - can be keywords, phrases, or semantic descriptions of what you're looking for"
      },
      "contexts": {
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "workflow",
            "session",
            "persistent",
            "shared"
          ]
        },
        "default": [
          "workflow",
          "session",
          "persistent",
          "shared"
        ],
        "description": "Which memory contexts to search in"
      },
      "search_type": {
        "type": "string",
        "enum": [
          "semantic",
          "exact",
          "pattern",
          "fuzzy"
        ],
        "default": "semantic",
        "description": "Type of search - semantic for meaning-based, exact for literal matches, pattern for regex, fuzzy for approximate"
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 20,
        "description": "Maximum number of results to return"
      },
      "time_range": {
        "type": "object",
        "properties": {
          "start": {
            "type": "string",
            "format": "date-time"
          },
          "end": {
            "type": "string",
            "format": "date-time"
          }
        },
        "description": "Filter results by when they were stored"
      }
    },
    "required": [
      "query"
    ]
  },
  "examples": [
    {
      "name": "Find team workflow steps",
      "parameters": {
        "query": "data collection analysis steps",
        "contexts": [
          "workflow"
        ],
        "search_type": "semantic",
        "limit": 10
      }
    },
    {
      "name": "Search for team error patterns",
      "parameters": {
        "query": "timeout error failure",
        "contexts": [
          "persistent"
        ],
        "search_type": "fuzzy"
      }
    },
    {
      "name": "Find recent team interactions",
      "parameters": {
        "query": "team preferences settings",
        "contexts": [
          "shared"
        ],
        "time_range": {
          "start": "2024-01-15T00:00:00Z"
        }
      }
    }
  ]
}