{
  "id": "func-github-get-file-sha",
  "name": "github_get_file_sha",
  "provider": "github",
  "function_group": "github",
  "display_name": "GitHub Get File SHA",
  "description": "Get the SHA hash of a specific file in a GitHub repository. This SHA is REQUIRED when calling github_create_update_file to update existing files. Use this function first to get the SHA, then pass it to github_create_update_file.",
  "endpoint": {
    "path": "/repos/{owner}/{repo}/contents/{path}",
    "method": "GET"
  },
  "parameters": {
    "required": ["owner", "repo", "path"],
    "optional": ["ref"],
    "schema": {"type": "object", "required": ["owner", "repo", "path"], "properties": {"ref": {"type": "string", "default": "main", "description": "Branch, tag, or commit SHA"}, "path": {"type": "string", "description": "Path to the file"}, "repo": {"type": "string", "description": "Repository name"}, "owner": {"type": "string", "description": "GitHub username or organization"}}}
  },
  "examples": [
    {
      "name": "Get file SHA",
      "parameters": {
        "owner": "microsoft",
        "repo": "vscode",
        "path": "README.md"
      }
    },
    {
      "name": "Get file SHA from specific branch",
      "parameters": {
        "owner": "facebook",
        "repo": "react",
        "path": "package.json",
        "ref": "develop"
      }
    }
  ]
}
