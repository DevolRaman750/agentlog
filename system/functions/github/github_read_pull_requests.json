{
  "id": "func-github-read-pull-requests",
  "name": "github_read_pull_requests",
  "provider": "github",
  "function_group": "github",
  "display_name": "GitHub: Read Pull Requests",
  "description": "Read and analyze pull requests from a GitHub repository. Get PR details including title, description, author, status, and branch information. Useful for reviewing pending changes and managing repository workflow.",
  "endpoint": {
    "path": "/repos/{owner}/{repo}/pulls",
    "method": "GET"
  },
  "parameters": {
    "type": "object",
    "properties": {
      "owner": {
        "type": "string",
        "description": "Repository owner (username or organization)"
      },
      "repo": {
        "type": "string",
        "description": "Repository name"
      },
      "state": {
        "type": "string",
        "enum": ["open", "closed", "all"],
        "default": "open",
        "description": "Pull request state filter"
      },
      "head": {
        "type": "string",
        "description": "Filter by head branch (e.g., 'feature-branch' or 'user:feature-branch')"
      },
      "base": {
        "type": "string",
        "description": "Filter by base branch (e.g., 'main', 'develop')"
      },
      "sort": {
        "type": "string",
        "enum": ["created", "updated", "popularity", "long-running"],
        "default": "created",
        "description": "Sort field"
      },
      "direction": {
        "type": "string",
        "enum": ["asc", "desc"],
        "default": "desc",
        "description": "Sort direction"
      },
      "per_page": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "default": 30,
        "description": "Number of results per page"
      }
    },
    "required": ["owner", "repo"]
  },
  "examples": [
    {
      "name": "Get open pull requests",
      "parameters": {
        "owner": "microsoft",
        "repo": "vscode",
        "state": "open",
        "per_page": 10
      }
    },
    {
      "name": "Get PRs for specific branch",
      "parameters": {
        "owner": "facebook",
        "repo": "react",
        "head": "feature-branch",
        "state": "open"
      }
    },
    {
      "name": "Get recently updated PRs",
      "parameters": {
        "owner": "google",
        "repo": "tensorflow",
        "sort": "updated",
        "direction": "desc"
      }
    }
  ]
}
