{
  "id": "func-github-list-branches",
  "name": "github_list_branches",
  "provider": "github",
  "function_group": "github",
  "display_name": "GitHub List Branches",
  "description": "List all branches in a GitHub repository. Useful for checking existing branches before creating new ones.",
  "endpoint": {
    "path": "/repos/{owner}/{repo}/branches",
    "method": "GET"
  },
  "parameters": {
    "type": "object",
    "required": [
      "owner",
      "repo"
    ],
    "properties": {
      "repo": {
        "type": "string",
        "description": "Repository name"
      },
      "owner": {
        "type": "string",
        "description": "GitHub username or organization"
      },
      "per_page": {
        "type": "integer",
        "default": 30,
        "maximum": 100,
        "minimum": 1
      },
      "protected": {
        "type": "boolean",
        "default": false,
        "description": "Filter to protected branches only"
      }
    }
  },
  "examples": [
    {
      "name": "List all branches",
      "parameters": {
        "owner": "microsoft",
        "repo": "vscode"
      }
    },
    {
      "name": "List protected branches only",
      "parameters": {
        "owner": "facebook",
        "repo": "react",
        "protected": true
      }
    }
  ]
}