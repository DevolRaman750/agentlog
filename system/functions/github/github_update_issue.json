{
  "id": "func-github-update-issue",
  "name": "github_update_issue",
  "provider": "github",
  "function_group": "github",
  "display_name": "GitHub Update Issue",
  "description": "Update a GitHub issue with additional analysis, insights, or findings. Perfect for AI agents to enhance issues with code analysis.",
  "endpoint": {
    "path": "/repos/{owner}/{repo}/issues/{issue_number}",
    "method": "PATCH"
  },
  "parameters": {
    "type": "object",
    "required": [
      "owner",
      "repo",
      "issue_number"
    ],
    "properties": {
      "body": {
        "type": "string",
        "description": "Updated issue description/body content (optional)"
      },
      "repo": {
        "type": "string",
        "description": "Repository name"
      },
      "owner": {
        "type": "string",
        "description": "GitHub username or organization name"
      },
      "state": {
        "enum": [
          "open",
          "closed"
        ],
        "type": "string",
        "description": "Issue state (optional)"
      },
      "title": {
        "type": "string",
        "description": "New title for the issue (optional)"
      },
      "issue_number": {
        "type": "integer",
        "minimum": 1,
        "description": "The issue number to update"
      }
    }
  },
  "examples": [
    {
      "name": "Update issue body",
      "parameters": {
        "owner": "microsoft",
        "repo": "vscode",
        "issue_number": 123,
        "body": "Updated issue description with additional analysis."
      }
    },
    {
      "name": "Close issue",
      "parameters": {
        "owner": "facebook",
        "repo": "react",
        "issue_number": 456,
        "state": "closed"
      }
    }
  ]
}