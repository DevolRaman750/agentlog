{
  "id": "func-github-search-code",
  "name": "github_search_code",
  "provider": "github",
  "function_group": "github",
  "display_name": "GitHub Search Code",
  "description": "Search for code patterns, file names, or functions within a GitHub repository. Useful for finding files when you don't know their exact location or when expected paths don't exist.",
  "endpoint": {
    "path": "/search/code",
    "method": "GET"
  },
  "parameters": {
    "required": ["owner", "repo", "query"],
    "optional": ["per_page"],
    "schema": {"type": "object", "required": ["owner", "repo", "query"], "properties": {"repo": {"type": "string", "description": "Repository name"}, "owner": {"type": "string", "description": "GitHub username or organization"}, "query": {"type": "string", "description": "Search query (code pattern, function name, etc.)"}, "per_page": {"type": "integer", "default": 30, "maximum": 100, "minimum": 1}}}
  },
  "examples": [
    {
      "name": "Search for function",
      "parameters": {
        "owner": "microsoft",
        "repo": "vscode",
        "query": "function main"
      }
    },
    {
      "name": "Search with higher limit",
      "parameters": {
        "owner": "facebook",
        "repo": "react",
        "query": "useState",
        "per_page": 50
      }
    }
  ]
}
