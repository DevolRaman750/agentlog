{
  "id": "github",
  "name": "github",
  "display_name": "GitHub",
  "description": "GitHub API integration with multiple authentication modes for repository management, issue tracking, and code analysis",
  "base_url": "https://api.github.com",
  "version": "2022-11-28",
  "auth_modes": [
    {
      "id": "personal_access_token",
      "name": "Personal Access Token",
      "description": "Use your personal GitHub token for API access",
      "is_default": true,
      "auth_config": {
        "header": "Authorization",
        "format": "token {token}",
        "description": "GitHub Personal Access Token"
      },
      "rate_limits": {
        "requests_per_hour": 5000,
        "authenticated_requests_per_hour": 5000
      },
      "setup": {
        "instructions": "Generate a Personal Access Token at https://github.com/settings/tokens",
        "required_scopes": ["repo", "read:user"],
        "fields": [
          {
            "name": "token",
            "type": "password",
            "label": "GitHub Personal Access Token",
            "placeholder": "ghp_xxxxxxxxxxxxxxxxxxxx",
            "required": true,
            "validation": "^ghp_[A-Za-z0-9]{36}$"
          }
        ]
      },
      "capabilities": {
        "rate_limit": "5000 requests/hour",
        "permissions": "User-level access to authorized repositories",
        "features": ["repository_access", "issue_management", "code_reading"]
      }
    },
    {
      "id": "github_app",
      "name": "GitHub App",
      "description": "Authenticate as a GitHub App installation for enhanced permissions and rate limits",
      "is_default": false,
      "auth_config": {
        "header": "Authorization",
        "format": "token {installation_token}",
        "description": "GitHub App Installation Token (generated from JWT)"
      },
      "rate_limits": {
        "requests_per_hour": 5000,
        "authenticated_requests_per_hour": 5000,
        "per_installation": true
      },
      "setup": {
        "instructions": "Create a GitHub App at https://github.com/settings/apps and install it to your repositories",
        "required_permissions": {
          "repository": ["contents:read", "issues:write", "pull_requests:write", "metadata:read"],
          "organization": ["members:read"]
        },
        "fields": [
          {
            "name": "app_id",
            "type": "number",
            "label": "GitHub App ID",
            "placeholder": "123456",
            "required": true,
            "help": "Found in your GitHub App settings"
          },
          {
            "name": "private_key",
            "type": "file",
            "label": "Private Key (.pem file)",
            "accept": ".pem",
            "required": true,
            "help": "Download from your GitHub App settings"
          },
          {
            "name": "installation_id",
            "type": "number",
            "label": "Installation ID",
            "placeholder": "12345678",
            "required": true,
            "help": "Found in the GitHub App installation URL"
          }
        ]
      },
      "capabilities": {
        "rate_limit": "5000 requests/hour per installation",
        "permissions": "Repository-level access with fine-grained permissions",
        "features": ["repository_access", "issue_management", "code_reading", "pr_management", "enhanced_permissions"],
        "benefits": [
          "Higher rate limits per installation",
          "Fine-grained repository permissions",
          "Organization audit logs",
          "Can act on behalf of the app",
          "Better for automation and CI/CD"
        ]
      }
    }
  ],
  "common_headers": {
    "Accept": "application/vnd.github+json",
    "X-GitHub-Api-Version": "2022-11-28",
    "User-Agent": "GoGent/1.0"
  },
  "error_handling": {
    "error_status_codes": [400, 401, 403, 404, 422, 500, 502, 503],
    "retry_status_codes": [500, 502, 503],
    "max_retries": 3,
    "auth_error_codes": [401, 403],
    "rate_limit_status_code": 403
  },
  "supported_functions": [
    "github_read_issues",
    "github_read_code", 
    "github_read_commits",
    "github_search_code",
    "github_create_issue",
    "github_update_issue",
    "github_add_comment",
    "github_create_pr",
    "github_create_branch"
  ]
}